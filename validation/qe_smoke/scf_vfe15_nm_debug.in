&CONTROL
  calculation = 'scf'
  prefix = 'vfe15_nm_debug'
  pseudo_dir = './pseudo'
  outdir = './tmp/vfe15_nm_debug'
  verbosity = 'high'
/
&SYSTEM
  ibrav = 0
  nat = 16
  ntyp = 2
  input_dft = 'pbesol'
  ecutwfc = 60
  ecutrho = 480
  occupations = 'smearing'
  smearing = 'mv'
  degauss = 0.04
/
&ELECTRONS
  conv_thr = 1.0d-5
  electron_maxstep = 100
  diagonalization = 'cg'
  mixing_mode = 'local-TF'
  mixing_beta = 0.20
/
